{
  "manifest_version": 3,
  "name": "Subito.it Price Filter",
  "version": "1.0.0",
  "description": "Filtra gli annunci Subito.it in base al prezzo, nascondendo quelli che non rientrano nei limiti impostati.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.subito.it/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.subito.it/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
